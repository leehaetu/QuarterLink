# QuarterLink QL-007 HMRC sandbox foundation placeholders.
# Copy values into an ignored .env.local file or deployment secret manager.
# Do not commit real HMRC client secrets, access tokens, refresh tokens, or production credentials.

APP_ENV=local
HMRC_ENV=sandbox

HMRC_SANDBOX_API_BASE_URL=https://test-api.service.hmrc.gov.uk
HMRC_SANDBOX_AUTH_BASE_URL=https://test-www.tax.service.gov.uk
HMRC_SANDBOX_CLIENT_ID=replace-with-hmrc-sandbox-client-id
HMRC_SANDBOX_CLIENT_SECRET=replace-with-hmrc-sandbox-client-secret
HMRC_SANDBOX_REDIRECT_URI=http://localhost:3000/api/hmrc/oauth/callback
HMRC_SANDBOX_SCOPES=replace-with-space-separated-sandbox-scopes
